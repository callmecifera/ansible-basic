$TTL    {{ time_to_live }}
@   IN  SOA ns1.{{ domain_name }}. admin.{{ domain_name }}. (
            {{ serial_number }}         ; Serial
            {{ refresh_time }}    ; Refresh
            {{ retry_time }}     ; Retry
            {{ expire_time }}   ; Expire
            {{ negative_cache_time }} )  ; Negative Cache TTL

@       IN  NS  ns1.{{ domain_name }}.
1       IN  PTR ns1.{{ domain_name }}.
1       IN  PTR {{ domain_name }}.
