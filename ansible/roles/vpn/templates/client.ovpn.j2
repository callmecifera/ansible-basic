# {{ ansible_managed }}
client
dev tun
proto {{ vpn_proto }}
remote {{ server_ip }} {{ vpn_port }}
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
cipher AES-256-GCM
auth SHA256
verb 3
key-direction 1

<ca>
{{ vpn_client_material.results[0].content | b64decode | trim }}
</ca>
<cert>
{{ vpn_client_material.results[1].content | b64decode | trim }}
</cert>
<key>
{{ vpn_client_material.results[2].content | b64decode | trim }}
</key>
<tls-auth>
{{ vpn_client_material.results[3].content | b64decode | trim }}
</tls-auth>
